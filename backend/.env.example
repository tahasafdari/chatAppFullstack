# MongoDB Atlas connection string. Free M0 cluster works fine.
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URL=

# 32+ random hex chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Origin allowed by CORS. For local dev, this is the Vite dev server.
# In production set to your Vercel URL (no trailing slash). You can supply
# multiple comma-separated origins, e.g.:
#   CLIENT_URL=http://localhost:5173,https://your-app.vercel.app
CLIENT_URL=http://localhost:5173
